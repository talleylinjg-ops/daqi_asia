---
const WC_SITE = "https://daqi.asia";
let products = [];
let productHtml = "";
let fetchError = false;

try {
  const res = await fetch(`${WC_SITE}/wp-json/wc/store/products`, {
    headers: { "Accept": "application/json" },
    signal: AbortSignal.timeout(10000)
  });
  if (res.ok) {
    products = await res.json();
    productHtml = `<div class="goods-grid">`;
    for (const item of products) {
      const img = item.images?.[0]?.thumbnail || "";
      const priceHtml = item.prices?.price_html || "";
      const productType = item.type || "simple";
      productHtml += `
        <div class="goods-card">
          <a href="/products/${item.id}">
            <img class="goods-img" src="${img}" alt="${item.name.replace(/"/g, '&quot;')}">
          </a>
          <a href="/products/${item.id}"><h4>${item.name}</h4></a>
          <div style="color:#c00;">${priceHtml}</div>
          <button class="add-cart-btn" type="button" data-pid="${item.id}" data-type="${productType}" onclick="handleAdd(this)">
            ${productType === 'variable' ? 'йҖүжӢ©и§„ж јеҠ е…Ҙ' : 'Add To Cart'}
          </button>
        </div>`;
    }
    productHtml += `</div>`;
  } else {
    fetchError = true;
  }
} catch (e) {
  console.error("иҺ·еҸ–е•Ҷе“ҒеӨұиҙҘ:", e);
  fetchError = true;
}
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<title>Daqi Asia зғӯеҚ–е•Ҷе“Ғ</title>
<style>
  .goods-wrap {max-width: 1240px;margin: 0 auto;padding: 20px;}
  .goods-grid {display: grid;grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));gap: 20px;}
  .goods-card {border: 1px solid #eee;padding: 12px;border-radius: 8px;background:#fff;}
  .goods-img {width: 100%;height: 200px;object-fit: cover;border-radius: 4px;}
  .add-cart-btn {width: 100%;padding: 8px 0;background: #007bff;color: #fff;border: none;border-radius: 4px;margin-top: 10px;cursor: pointer;}
  .loading-tip {text-align: center;font-size: 16px;padding: 30px 0;color:#999;}
  .modal-mask {position: fixed;inset: 0;background: rgba(0,0,0,0.5);display: flex;align-items: center;justify-content: center;z-index:999;}
  .modal-box {background:#fff;padding:24px;border-radius:10px;width:90%;max-width:500px;}
  .attr-row {margin:12px 0;}
  .attr-label {display:block;margin-bottom:6px;font-weight:bold;}
  select {width:100%;padding:8px;border:1px solid #ddd;border-radius:4px;}
  .modal-btns {display:flex;gap:10px;margin-top:20px;}
  .cancel-btn {flex:1;padding:10px;border:1px solid #999;background:#fff;cursor:pointer;}
  .confirm-btn {flex:1;padding:10px;background:#007bff;color:#fff;border:none;cursor:pointer;}
  .fixed-cart-btn {position:fixed;top:10px;right:10px;padding:6px 12px;background:#333;color:#fff;border:none;border-radius:4px;cursor:pointer;z-index:100;}
</style>
</head>
<body>
<button class="fixed-cart-btn" type="button" onclick="openCart()">View Cart</button>
<h2 style="text-align:center;">рҹӣ’ Daqi Asia зғӯеҚ–е•Ҷе“Ғ</h2>

{fetchError ? '<p style="text-align:center;color:#c00;padding:20px;">е•Ҷе“Ғж•°жҚ®еҠ иҪҪеӨұиҙҘпјҢиҜ·зЁҚеҗҺеҲ·ж–°йҮҚиҜ•</p>' : ''}

<div class="goods-wrap">
  <div class="goods-box" set:html={productHtml}></div>
</div>
<div id="varModal" style="display:none;"></div>

<script is:inline>
const WC_SITE = "https://daqi.asia";
let allVarsData = null;
window.selectedAttrs = {};

async function openCart(){
  const res = await fetch(`${WC_SITE}/wp-json/wc/store/cart`,{credentials:"include"});
  const cart = await res.json();
  console.log("иҙӯзү©иҪ?, cart);
  alert("F12жҺ§еҲ¶еҸ°жҹҘзңӢиҙӯзү©иҪҰ");
}

async function ajaxAddCart(pid, vid, qty, attrs){
  const fd = new FormData();
  fd.append('action','custom_ajax_add_cart');
  fd.append('pid',pid);
  fd.append('vid',vid);
  fd.append('qty',qty);
  fd.append('attrs',JSON.stringify(attrs));
  try {
    const resp = await fetch(`${WC_SITE}/wp-admin/admin-ajax.php`,{
      method:"POST",
      body: fd,
      credentials:"include"
    });
    const ret = await resp.json();
    if(ret.success){
      alert(ret.data.msg + " еҪ“еүҚиҙӯзү©иҪҰж•°йҮҸпјҡ" + ret.data.cart_count);
      document.getElementById("varModal").style.display = "none";
      window.selectedAttrs = {};
    } else {
      alert(ret.data.msg);
    }
  } catch(err) {
    alert("зҪ‘з»ңиҜ·жұӮеӨұиҙҘ");
    console.error(err);
  }
}

async function openVarModal(pid){
  try {
    const res = await fetch(`${WC_SITE}/wp-json/custom/v1/products/${pid}/vars`,{credentials:"include"});
    if (!res.ok) {
      alert("иҺ·еҸ–е•Ҷе“Ғи§„ж јеӨұиҙҘпјҢиҜ·йҮҚиҜ•");
      return;
    }
    const data = await res.json();
    const {attributes} = data;
    if (!attributes || Object.keys(attributes).length === 0) {
      // жІЎжңүеұһжҖ§йңҖиҰҒйҖүжӢ©пјҢзӣҙжҺҘеҠ иҙ?      alert("иҜҘе•Ҷе“ҒжҡӮж— и§„ж јеҸҜйҖ?);
      return;
    }
    allVarsData = data;
    let html = `<div class="modal-mask" onclick="closeModal(event)"><div class="modal-box" onclick="event.stopPropagation()"><h3>йҖүжӢ©е•Ҷе“Ғи§„ж ј</h3>`;
    Object.keys(attributes).forEach(key=>{
      const name = key.replace('pa_','');
      html += `<div class="attr-row"><label class="attr-label">${name}</label><select data-attr="${key}" onchange="window.selectedAttrs['${key}']=this.value"><option value="">иҜ·йҖүжӢ©${name}</option>`;
      attributes[key].forEach(opt=>{
        html += `<option value="${opt}">${opt}</option>`;
      });
      html += `</select></div>`;
    });
    html += `<div class="modal-btns"><button class="cancel-btn" type="button" onclick="closeModal()">еҸ–ж¶Ҳ</button><button class="confirm-btn" type="button" onclick="submitVar(${pid})">зЎ®и®ӨеҠ е…Ҙ</button></div></div></div>`;
    document.getElementById("varModal").innerHTML = html;
    document.getElementById("varModal").style.display = "block";
  } catch(err) {
    console.error("еҸҳдҪ“жҺҘеҸЈиҜ·жұӮејӮеёё", err);
    alert("е•Ҷе“Ғи§„ж јеҠ иҪҪеӨұиҙҘпјҢиҜ·йҮҚиҜ•");
  }
}

function closeModal(e){
  if(e && e.target !== e.currentTarget) return;
  document.getElementById("varModal").style.display = "none";
  window.selectedAttrs = {};
}

function getMatchVid(){
  if(!allVarsData) return null;
  const {variations} = allVarsData;
  for(const v of variations){
    let match = true;
    for(const k in window.selectedAttrs){
      if(v.attributes[k] !== window.selectedAttrs[k]){
        match = false;
        break;
      }
    }
    if(match) return v.variation_id;
  }
  return null;
}

async function submitVar(pid){
  const vid = getMatchVid();
  if(!vid){
    alert("иҜ·е®Ңж•ҙйҖүжӢ©жүҖжңүи§„ж ?);
    return;
  }
  await ajaxAddCart(pid, vid, 1, window.selectedAttrs);
}

// дҪҝз”Ё data-* еұһжҖ§жқҘеҲӨж–ӯе•Ҷе“Ғзұ»еһӢпјҢжҜ”еӯ—з¬ҰдёІеҸӮж•°жӣҙеҸҜйқ 
window.handleAdd = function(btn){
  const pid = Number(btn.dataset.pid);
  const productType = btn.dataset.type;
  console.log("handleAdd triggered:", {pid, productType});
  if(productType === "simple"){
    ajaxAddCart(pid, 0, 1, []);
  } else {
    openVarModal(pid);
  }
}
</script>
</body>
</html>
