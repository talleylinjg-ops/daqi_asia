---
const WC_SITE = "https://daqi.asia";

export async function getStaticPaths() {
  let products = [];
  try {
    const res = await fetch(`${WC_SITE}/wp-json/wc/store/products`, {
      headers: { "Accept": "application/json" },
      signal: AbortSignal.timeout(8000)
    });
    if (res.ok) {
      products = await res.json();
    }
  } catch (e) {
    console.error("获取商品列表失败:", e);
  }
  return {
    paths: products.map(p => ({params:{id:String(p.id)}})),
    fallback: "blocking"
  };
}

const {id} = Astro.params;
let product = null;
let fetchError = false;

try {
  const productRes = await fetch(`${WC_SITE}/wp-json/wc/store/products/${id}`, {
    headers: { "Accept": "application/json" },
    signal: AbortSignal.timeout(8000)
  });
  if (productRes.ok) {
    product = await productRes.json();
  } else {
    fetchError = true;
  }
} catch (e) {
  console.error(`获取商品 ${id} 失败:`, e);
  fetchError = true;
}
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<title>{product?.name || "商品详情 - Daqi Asia"}</title>
<style>
.detail-wrap {max-width:1200px;margin:30px auto;display:grid;grid-template-columns:1fr 1fr;gap:40px;padding:0 20px;}
.main-img {width:100%;height:420px;object-fit:cover;border-radius:8px;}
.price-text {font-size:22px;color:#d00;margin:15px 0;}
.qty-input {width:70px;padding:8px;margin-right:10px;}
.add-cart-btn {padding:10px 24px;background:#007bff;color:#fff;border:none;border-radius:4px;font-size:16px;cursor:pointer;}
.modal-mask {position:fixed;inset:0;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;z-index:999;}
.modal-box {background:#fff;padding:24px;border-radius:10px;width:90%;max-width:500px;}
.attr-row {margin:12px 0;}
.attr-label {display:block;margin-bottom:6px;font-weight:bold;}
select {width:100%;padding:8px;border:1px solid #ddd;border-radius:4px;}
.modal-btns {display:flex;gap:10;margin-top:20px;}
.cancel-btn {flex:1;padding:10px;border:1px solid #999;background:#fff;cursor:pointer;}
.confirm-btn {flex:1;padding:10px;background:#007bff;color:#fff;border:none;cursor:pointer;}
.fixed-cart-btn {position:fixed;top:10px;right:10px;padding:6px 12px;background:#333;color:#fff;border:none;border-radius:4px;cursor:pointer;z-index:100;}
</style>
</head>
<body>
<button class="fixed-cart-btn" type="button" onclick="openCart()">View Cart</button>

{fetchError ? '<div style="max-width:800px;margin:40px auto;text-align:center;padding:40px;"><h2>商品加载失败</h2><p style="color:#999;">请返回首页重试</p><a href="/" style="display:inline-block;margin-top:20px;padding:10px 24px;background:#007bff;color:#fff;text-decoration:none;border-radius:4px;">返回首页</a></div>' : ''}

{product ? `
<div class="detail-wrap">
  <div><img class="main-img" src="${product.images?.[0]?.src || ''}" alt="${product.name}"></div>
  <div>
    <h1>${product.name}</h1>
    <div class="price-text">${product.prices?.price_html || ''}</div>
    <div style="margin:20px 0;">${product.description || ''}</div>
    <input class="qty-input" id="qty" value="1" min="1" type="number">
    <button class="add-cart-btn" type="button" onclick="handleDetailAdd()">
      ${product.type === 'variable' ? '选择规格加入购物车' : '加入购物车'}
    </button>
  </div>
</div>
<div id="varModal" style="display:none;"></div>
` : ''}

<script is:inline>
const WC_SITE = "https://daqi.asia";
const pid = Number("{product?.id ?? ''}");
const productType = "{product?.type ?? ''}";
let allVarsData = null;
window.selectedAttrs = {};

async function openCart(){
  const res = await fetch(`${WC_SITE}/wp-json/wc/store/cart`,{credentials:"include"});
  const cart = await res.json();
  console.log("购物车", cart);
  alert("F12控制台查看购物车");
}

async function ajaxAddCart(pid, vid, qty, attrs){
  const fd = new FormData();
  fd.append('action','custom_ajax_add_cart');
  fd.append('pid',pid);
  fd.append('vid',vid);
  fd.append('qty',qty);
  fd.append('attrs',JSON.stringify(attrs));
  try {
    const resp = await fetch(`${WC_SITE}/wp-admin/admin-ajax.php`,{
      method:"POST",
      body: fd,
      credentials:"include"
    });
    const ret = await resp.json();
    if(ret.success){
      alert(ret.data.msg + " 购物车数量：" + ret.data.cart_count);
      document.getElementById("varModal").style.display = "none";
      window.selectedAttrs = {};
    } else {
      alert(ret.data.msg);
    }
  } catch(err) {
    alert("加购失败");
    console.error(err);
  }
}

function closeModal(e){
  if(e && e.target !== e.currentTarget) return;
  document.getElementById("varModal").style.display = "none";
  window.selectedAttrs = {};
}

function getMatchVid(){
  if(!allVarsData) return null;
  const {variations} = allVarsData;
  for(const v of variations){
    let match = true;
    for(const k in window.selectedAttrs){
      if(v.attributes[k] !== window.selectedAttrs[k]){
        match = false;
        break;
      }
    }
    if(match) return v.variation_id;
  }
  return null;
}

async function submitDetailVar(qty){
  const vid = getMatchVid();
  if(!vid){
    alert("请完整选择所有规格");
    return;
  }
  await ajaxAddCart(pid, vid, qty, window.selectedAttrs);
}

async function handleDetailAdd(){
  const qty = Number(document.getElementById("qty").value) || 1;
  if(productType === "simple"){
    await ajaxAddCart(pid, 0, qty, []);
  } else {
    const res = await fetch(`${WC_SITE}/wp-json/custom/v1/products/${pid}/vars`,{credentials:"include"});
    allVarsData = await res.json();
    const {attributes} = allVarsData;
    let html = `<div class="modal-mask" onclick="closeModal(event)"><div class="modal-box" onclick="event.stopPropagation()"><h3>选择规格</h3>`;
    Object.keys(attributes).forEach(key=>{
      const name = key.replace('pa_','');
      html += `<div class="attr-row"><label class="attr-label">${name}</label><select data-attr="${key}" onchange="window.selectedAttrs['${key}']=this.value"><option value="">请选择</option>`;
      attributes[key].forEach(opt=>{
        html += `<option value="${opt}">${opt}</option>`;
      });
      html += `</select></div>`;
    });
    html += `<div class="modal-btns"><button class="cancel-btn" type="button" onclick="closeModal()">取消</button><button class="confirm-btn" type="button" onclick="submitDetailVar(${qty})">确认加入${qty}件</button></div></div></div>`;
    document.getElementById("varModal").innerHTML = html;
    document.getElementById("varModal").style.display = "block";
  }
}
</script>
</body>
</html>